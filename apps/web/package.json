{
  "name": "statskills-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Clickable demo UI for the statskills harness: submit a run, watch the agent's steps stream, read the traceable report (ROADMAP §11).",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run --passWithNoTests"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tsconfig/svelte": "^5.0.8",
    "prettier": "^3.9.4",
    "prettier-plugin-svelte": "^4.1.1",
    "svelte": "^5.56.4",
    "svelte-check": "^4.7.1",
    "tslib": "^2.8.1",
    "typescript": "^6.0.3",
    "vite": "^8.1.1",
    "vitest": "^4.1.9"
  }
}
