# EdenAI is the model gateway for this project (OpenAI-compatible endpoint, reached
# via the `openai` SDK with base_url=https://api.edenai.run/v3). Get a key at
# https://www.edenai.co/, then copy this file to `.env` and fill it in.
EDENAI_API_KEY=your_edenai_key_here

# Optional — use a local Ollama server instead (set provider: ollama; no key needed).
# Only set this if the default http://localhost:11434/v1 can't reach Ollama, e.g.
# Ollama on the Windows host from WSL: start it with OLLAMA_HOST=0.0.0.0 and put the
# full OpenAI-compatible base URL here.
# OLLAMA_BASE_URL=http://localhost:11434/v1
